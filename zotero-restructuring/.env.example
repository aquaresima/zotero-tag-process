# ZoteroRestructuring environment variables
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.

# Path to the Zotero SQLite database (optional; default: ~/Zotero/zotero.sqlite)
ZOTERO_SQLITE_PATH=

# Zotero API key — required for Phase 4 (export/upload) and optional Phase 1 fallback
# Obtain from: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=

# OpenAI API key — required for Phase 3 semantic clustering (deferred)
OPENAI_API_KEY=
